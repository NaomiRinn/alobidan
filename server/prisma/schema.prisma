generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  phone     String?
  role      String    @default("patient")
  avatar    String?
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Service {
  id             Int       @id @default(autoincrement())
  name           String
  specialization String
  hospital       String
  rating         Float
  reviews        Int
  experience     String
  price          Int
  avatar         String?
  initials       String
  color          String
  available      Boolean   @default(true)
  schedule       String[]
  about          String    @db.Text
  education      String[]
  languages      String[]
  bookings       Booking[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Booking {
  id           Int      @id @default(autoincrement())
  userId       Int?
  user         User?    @relation(fields: [userId], references: [id])
  serviceId    Int
  service      Service  @relation(fields: [serviceId], references: [id])
  serviceName  String
  serviceSpec  String
  midwifeName  String
  day          String
  time         String
  complaint    String?
  price        Int
  patientName  String
  patientPhone String?
  status       String   @default("confirmed")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Symptom {
  id    Int     @id @default(autoincrement())
  slug  String  @unique
  label String
}

model Disease {
  id               Int      @id @default(autoincrement())
  name             String
  severity         String
  description      String   @db.Text
  recommendation   String   @db.Text
  specialist       String
  urgency          String
  symptoms         String[]
  requiredSymptoms String[]
}
